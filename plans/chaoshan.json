  "data": {
    "days": [
      {
        "title": "Day 1 · 6.18 · 抵达汕头",
        "level": "中等",
        "c": "shantou",
        "items": [
          {
            "time": "13:30",
            "text": "三人抵达酒店集合，办理入住！"
          },
          {
            "time": "14:00",
            "text": "开吃！吃饱喝足才能好好玩！"
          },
          {
            "time": "15:30",
            "text": "从小公园开始逛 网红路线打卡（N个地方，所以中午要好好吃）........."
          },
          {
            "time": "18:30",
            "text": "去广场码头看日落！"
          },
          {
            "time": "19:00",
            "text": "去吃饭"
          },
          {
            "time": "20:30",
            "text": "沿着沿海长廊晚上走走散散步，消化消化食"
          },
          {
            "time": "22:00",
            "text": "可以去万象城/龙眼南路去吃小吃夜宵（全是小摊小贩）"
          }
        ]
      },
      {
        "title": "Day 2 · 6.19 · 汕头老城 → 南澳",
        "level": "中等",
        "c": "shantou",
        "items": [
          {
            "time": "10:00",
            "text": "如果前天晚上喝酒，就可以多睡一会，醒了之后收拾行李"
          },
          {
            "time": "12:00",
            "text": "再从汕头吃一顿（到时候找顿推荐的餐厅）"
          },
          {
            "time": "14:00",
            "text": "然后出发南澳岛"
          },
          {
            "time": "15:00",
            "text": "入住酒店"
          },
          {
            "time": "15:30",
            "text": "长山尾灯塔→环岛公路→青澳湾日落"
          },
          {
            "time": "20:00",
            "text": "吃顿大排档！！！哈啤酒，吃嘎喇"
          },
          {
            "time": "22:30",
            "text": "可以早点回酒店 唠唠嗑 看个电影 早点休息"
          }
        ]
      },
      {
        "title": "Day 3 · 6.20 · 环南澳 → 潮州",
        "level": "中等",
        "c": "nanao",
        "items": [
          {
            "time": "06:30",
            "text": "青澳湾日出→自然之门→三囱崖灯塔→风车山→云澳渔港"
          },
          {
            "time": "12:00",
            "text": "吃个午饭"
          },
          {
            "time": "13:30",
            "text": "云澳监督站 → 三囱崖灯塔 → 青澳湾自然之门，南澳最经典点位"
          },
          {
            "time": "16:30",
            "text": "出岛回汕头站，动车到潮汕站，打车进潮州古城"
          },
          {
            "time": "18:00",
            "text": "办入住"
          },
          {
            "time": "20:00",
            "text": "牌坊街 + 南门夜市 + 广济桥外侧夜景"
          }
        ]
      },
      {
        "title": "Day 4 · 6.21 · 潮州古城 → 返程",
        "level": "灵活",
        "c": "chaozhou",
        "items": [
          {
            "time": "09:00",
            "text": "西湖公园 → 许驸马府 → 己略黄公祠"
          },
          {
            "time": "11:00",
            "text": "开元寺 → 甲第巷 → 牌坊街"
          },
          {
            "time": "13:30",
            "text": "可以尝尝午餐潮州卤鹅和粿条"
          },
          {
            "time": "15:00",
            "text": "广济桥 →韩文公祠 → 泰佛殿"
          },
          {
            "time": "18:30",
            "text": "打道回府"
          }
        ]
      }
    ],
